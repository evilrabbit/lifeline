{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "evilrabbit",
  "homepage": "https://github.com/evilrabbit/lifeline",
  "items": [
    {
      "name": "lifeline",
      "type": "registry:block",
      "title": "Lifeline",
      "description": "An interactive timeline of a life — horizontal on desktop, vertical on mobile, with floating photo cards, hover media, a tap-to-expand lightbox, and a cinematic intro.",
      "dependencies": [
        "lucide-react",
        "next-themes"
      ],
      "registryDependencies": [
        "utils"
      ],
      "files": [
        {
          "path": "components/lifeline/company-icon.tsx",
          "type": "registry:component",
          "target": "components/lifeline/company-icon.tsx"
        },
        {
          "path": "components/lifeline/index.ts",
          "type": "registry:component",
          "target": "components/lifeline/index.ts"
        },
